{
  "name": "landing-sveltekit-landing",
  "version": "2.0.0",
  "private": true,
  "description": "Landing page кафе 'Три Фреймворка' (SvelteKit + Svelte 5)",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview --port 3000",
    "start": "node -r dotenv/config build/index.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  }
}
