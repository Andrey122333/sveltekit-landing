{
  "name": "nir3-sveltekit-landing",
  "version": "2.0.0",
  "private": true,
  "description": "Landing page кафе 'Три Фреймворка' (SvelteKit + Svelte 5)",
  "scripts": {
    "dev": "vite dev --port 3001",
    "build": "vite build",
    "preview": "vite preview --port 3001",
    "start": "node -r dotenv/config build/index.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.0.1",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^3.6.3",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  }
}
